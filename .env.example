# Copy this file to `.env` and fill in your own values.
#   cp .env.example .env
#
# NEVER commit your real `.env` — it holds secrets. It is already gitignored.

# --- Required ---------------------------------------------------------------

# Your OpenRouter API key. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# --- Options (sensible defaults) --------------------------------------------

# Which model each tier ("fast", "balanced", "smart", ...) maps to is set in
# code, in src/agent/services/llm.py — not here. Pick a model in code with
# build_model("smart"); no env var needed.

# Logging verbosity: DEBUG, INFO, WARNING, or ERROR.
LOG_LEVEL=INFO

# Password for deployed web apps. Leave unset locally; SET IT before you deploy a
# web demo publicly, so it's behind a login.
# APP_PASSWORD=change-me

# --- Media: fal.ai (only if you generate images/video/audio) ----------------

# Get a key at https://fal.ai/dashboard/keys
# FAL_KEY=...

# --- Storage: Cloudflare R2 (only if you store files) -----------------------
# All four are needed together. From your Cloudflare R2 dashboard.
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET=...
# If the bucket is shared, your instructor gives you a prefix that scopes your
# slice of it. The storage service adds/strips it automatically.
# R2_PREFIX=student07
# Public/custom domain on the bucket — lets storage.public_url() build stable
# links (no expiry) that you can save in the DB and render later.
# R2_PUBLIC_BASE_URL=https://files.example.com

# --- Database: Neon Postgres (only if you use a database) -------------------

# Neon connection string. Use the "pooled" connection URL.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Environment ------------------------------------------------------------
# Which environment this process runs in: "development" (default) or "production".
# Same code, different values per environment — see examples/inspiration_bot.
# ENVIRONMENT=development

# --- Telegram bot (only for the inspiration_bot example) --------------------
# Token from @BotFather (/newbot). IMPORTANT: use a DIFFERENT token for dev and
# prod — Telegram allows only one update-consumer per token, so a dev poller and a
# prod webhook on the same token collide (409 Conflict).
# TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# Optional allowlist of Telegram user ids (authorization). Empty = open to anyone.
# ALLOWED_TELEGRAM_IDS=11111111,22222222
# The next three are only needed in PRODUCTION (set them as Railway variables):
#   PUBLIC_URL              public base URL of the deployed app, to register the webhook
#   TELEGRAM_WEBHOOK_SECRET random string Telegram echoes back so we can verify calls
#   CRON_SECRET             random string required on the POST /cron/tick endpoint
# PUBLIC_URL=https://your-app.up.railway.app
# TELEGRAM_WEBHOOK_SECRET=some-long-random-string
# CRON_SECRET=another-long-random-string
